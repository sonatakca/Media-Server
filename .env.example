# Frontend variables are read by Vite in the browser app.
VITE_DEFAULT_JELLYFIN_SERVER_URL=https://izle.sonatakca.com
VITE_SEYIRLIK_PLAYBACK_BACKEND_URL=http://127.0.0.1:43110

# Backend variables are read by `npm run playback:backend`.
# The backend script loads `.env` through Node's `--env-file=.env` flag.
SEYIRLIK_PLAYBACK_BACKEND_HOST=127.0.0.1
SEYIRLIK_PLAYBACK_BACKEND_PORT=43110
SEYIRLIK_MEDIA_ROOT=/absolute/path/to/media
SEYIRLIK_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Windows server example:
# SEYIRLIK_PLAYBACK_BACKEND_HOST=0.0.0.0
# SEYIRLIK_MEDIA_ROOT=D:/media